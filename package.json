{
  "name": "lolhelper",
  "version": "0.1.0",
  "private": true,
  "description": "LoL Arena & Mayhem augment/item statistics helper",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "frontend:dev": "pnpm --filter @lolhelper/frontend dev",
    "client:dev": "pnpm --filter @lolhelper/client dev",
    "backend:dev": "uv --directory backend run uvicorn app.main:app --reload",
    "backend:worker": "uv --directory backend run arq app.workers.settings.WorkerSettings",
    "backend:migrate": "uv --directory backend run alembic upgrade head",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "@types/node": "^22.10.0"
  }
}
