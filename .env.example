# ========================================
# LOL Helper Environment Variables (example)
# Copy to .env and fill in actual values
# ========================================

# --- Database ---
POSTGRES_USER=lolhelper
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=lolhelper
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://lolhelper:changeme_in_production@localhost:5432/lolhelper

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- Riot Games API ---
# Comma-separated list of API keys (for rotation). Personal keys expire every 24h.
# Get from https://developer.riotgames.com/
RIOT_API_KEYS=RGAPI-your-key-here
# Default region cluster for initial crawl seed: americas | asia | europe | sea
RIOT_DEFAULT_CLUSTER=asia
# Seed regions (challenger/GM/master pull): KR,NA1,EUW1,EUN1,JP1,BR1,LA1,LA2,OC1,TR1,RU,VN2,TW2,SG2,TH2,PH2
RIOT_SEED_REGIONS=KR,JP1,TW2

# --- Auth (Google OAuth) ---
# Create OAuth client at https://console.cloud.google.com/apis/credentials
# In the Google Console, set "Authorized redirect URIs" to the value below
# (frontend proxies it to the backend so cookies land on the frontend origin).
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/proxy/auth/google/callback
# 32-byte secret for signing JWTs; openssl rand -hex 32
JWT_SECRET=replace_me_with_random_32_byte_hex
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# --- App ---
APP_ENV=development
APP_NAME=lolhelper
APP_HOST=0.0.0.0
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:51820

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=LOL Helper
REVALIDATE_SECRET=replace_me_for_isr_webhook

# --- Client (.exe) ---
# Backend URL the client will hit
LOLHELPER_BACKEND_URL=http://localhost:8000
# OAuth loopback port
LOLHELPER_OAUTH_LOOPBACK_PORT=51820

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
